{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "alwaysStrict": false,
    "skipLibCheck": true,
    "resolveJsonModule": false
  },
  "include": [
    "globals.d.ts",
    "js/utilidades.js",
    "js/config.js",
    "js/datos.js",
    "js/empleados.js",
    "js/rotaciones.js",
    "js/cobertura.js",
    "js/reglas.js",
    "js/motor-sustituciones.js",
    "js/ausencias.js",
    "js/intercambios.js",
    "js/reemplazos.js",
    "js/horas.js",
    "js/auditor.js",
    "js/sync.js",
    "js/festivos.js",
    "js/control.js",
    "js/hoy-ui.js",
    "js/calendario-ui.js",
    "js/ausencias-ui.js",
    "js/empleados-ui.js",
    "js/pdf.js",
    "js/modales/modales-base.js",
    "js/modales/modales-ausencia.js",
    "js/modales/modales-sustitucion.js",
    "js/modales/modales-refuerzo.js",
    "js/modales/modales-empleado.js",
    "js/modales/modales-intercambio.js",
    "js/modales/modales-reemplazo.js"
  ]
}
